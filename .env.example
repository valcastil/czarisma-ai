# Stripe Configuration
# Get these from https://dashboard.stripe.com/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Supabase Configuration (already set in lib/supabase.ts)
# EXPO_PUBLIC_SUPABASE_URL=your_supabase_url
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# SMTP Configuration (Hostinger)
# Get these from your Hostinger email account settings
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_ADMIN_EMAIL=your-email@yourdomain.com

# Google OAuth Configuration
# Get these from https://console.cloud.google.com/
# 1. Create a project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web application type for Supabase)
# 4. Add authorized redirect URI: https://gdgbuvgmzaqeajwxhldr.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Gemini AI Configuration
# Get your API key from https://makersuite.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key-here

# Vexo Analytics Configuration
# Get your API key from https://vexo.co/
EXPO_PUBLIC_VEXO_API_KEY=your-vexo-api-key-here

# RevenueCat Configuration
# Get these from https://app.revenuecat.com/
# Create separate API keys for iOS and Android
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your-revenuecat-ios-key-here
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=your-revenuecat-android-key-here
