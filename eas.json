{
  "cli": {
    "version": ">= 13.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "resourceClass": "m-medium",
        "simulator": true
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "preview": {
      "environment": "preview",
      "distribution": "internal",
      "channel": "preview",
      "autoIncrement": true,
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -Dorg.gradle.warning.mode=none",
        "withoutCredentials": false
      },
      "env": {
        "APP_VARIANT": "preview",
        "EXPO_PUBLIC_SUPABASE_URL": "$EXPO_PUBLIC_SUPABASE_URL",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "$EXPO_PUBLIC_SUPABASE_ANON_KEY",
        "EXPO_PUBLIC_GEMINI_API_KEY": "$EXPO_PUBLIC_GEMINI_API_KEY",
        "EXPO_PUBLIC_VEXO_API_KEY": "$EXPO_PUBLIC_VEXO_API_KEY",
        "EXPO_PUBLIC_ELEVENLABS_API_KEY": "$EXPO_PUBLIC_ELEVENLABS_API_KEY"
      }
    },
    "production": {
      "environment": "production",
      "channel": "production",
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium",
        "simulator": false
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_VARIANT": "production",
        "EXPO_PUBLIC_SUPABASE_URL": "$EXPO_PUBLIC_SUPABASE_URL",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "$EXPO_PUBLIC_SUPABASE_ANON_KEY",
        "EXPO_PUBLIC_GEMINI_API_KEY": "$EXPO_PUBLIC_GEMINI_API_KEY",
        "EXPO_PUBLIC_VEXO_API_KEY": "$EXPO_PUBLIC_VEXO_API_KEY",
        "EXPO_PUBLIC_ELEVENLABS_API_KEY": "$EXPO_PUBLIC_ELEVENLABS_API_KEY"
      }
    },
    "production-apk": {
      "extends": "production",
      "android": {
        "buildType": "apk"
      },
      "channel": "production-apk"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "castilv@gmail.com",
        "ascAppId": "6761360239",
        "appleTeamId": "32SWJDNB5Z",
        "sku": "charisma-chat-ios"
      },
      "android": {
        "serviceAccountKeyPath": "./credentials/play-store-service-account.json",
        "track": "production",
        "releaseStatus": "completed"
      }
    },
    "preview": {
      "android": {
        "serviceAccountKeyPath": "./credentials/play-store-service-account.json",
        "track": "internal"
      }
    }
  }
}
