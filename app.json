{
  "expo": {
    "name": "Czar AI",
    "slug": "charisma-chat",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/adaptive-icon.png",
    "scheme": "charismachat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "frznfrg",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/41fc9874-9a30-4bf1-9523-383d1480ed52"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aiagentmaker.charismachat",
      "icon": "./assets/images/icon.png",
      "googleServicesFile": "./GoogleService-Info.plist",
      "config": {
        "googleMapsApiKey": "AIzaSyAfG8QcFSZS465qDzQBLKyupeVGyvYX_dM"
      },
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:charismachat.app"
      ],
      "infoPlist": {
        "CFBundleDisplayName": "Czar AI",
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "This app needs access to your microphone to transcribe voice messages.",
        "NSSpeechRecognitionUsageDescription": "This app needs access to speech recognition to convert your voice to text.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to send and receive images and videos in messages.",
        "NSCameraUsageDescription": "This app needs access to your camera to take photos and videos for messages.",
        "NSPhotoLibraryAddUsageDescription": "This app needs permission to save photos and videos.",
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to share it in chats.",
        "NSUserTrackingUsageDescription": "This identifier is used to deliver personalized features and measure usage anonymously. You can opt out anytime.",
        "NSUserActivityTypes": [
          "NSUserActivityTypeBrowsingWeb"
        ],
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "charismachat"
            ],
            "CFBundleURLName": "com.aiagentmaker.charismachat"
          }
        ],
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/splash-icon-dark.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/splash-icon-light.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.aiagentmaker.charismachat",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAfG8QcFSZS465qDzQBLKyupeVGyvYX_dM"
        }
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "*.charismachat.app",
              "pathPrefix": "/share"
            },
            {
              "scheme": "charismachat"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "SEND",
          "category": [
            "DEFAULT"
          ],
          "data": [
            {
              "mimeType": "text/plain"
            }
          ]
        }
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "expo-router",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to use your microphone for voice messages and speech-to-text."
        }
      ],
      "expo-image-picker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to share it in chats."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "This app needs access to your photo library to save images and videos.",
          "savePhotosPermission": "This app needs permission to save photos and videos to your gallery.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-dark.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "image": "./assets/images/splash-icon-light.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "This app needs access to your microphone to transcribe voice messages.",
          "speechRecognitionPermission": "This app needs access to speech recognition to convert your voice to text."
        }
      ],
      "./plugins/withJetifier.js",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "16.0"
          }
        }
      ],
      "./plugins/withNonModularHeaders.js",
      "./plugins/withGoogleMapsSubspec.js",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "41fc9874-9a30-4bf1-9523-383d1480ed52"
      },
      "geminiApiKey": "",
      "elevenLabsApiKey": ""
    }
  }
}
